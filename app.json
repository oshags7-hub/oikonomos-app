{
  "expo": {
    "name": "Oikonomos",
    "slug": "oikonomos",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FAF8F4"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.oikonomos.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FAF8F4"
      },
      "package": "com.oikonomos.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-asset",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#C07B5A"
        }
      ],
      [
        "expo-calendar",
        {
          "calendarPermission": "Oikonomos needs calendar access to show your events."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "scheme": "oikonomos"
  }
}
